{
  "name": "@rbillon59/vinted-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for interacting with the Vinted marketplace",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vinted-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
